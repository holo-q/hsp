{
  "name": "hsp",
  "version": "0.16.0",
  "description": "Harness Server Protocol: one MCP plugin that selects the right LSP for the workspace",
  "author": {
    "name": "holo-q"
  },
  "repository": "https://github.com/holo-q/hsp",
  "license": "MIT",
  "keywords": ["hsp", "lsp", "language-server", "python", "csharp", "rust", "mcp"],
  "lspServers": {
    "ty": {
      "command": "ty",
      "args": ["server"],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    },
    "basedpyright": {
      "command": "basedpyright-langserver",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    },
    "csharp-ls": {
      "command": "csharp-ls",
      "args": [],
      "extensionToLanguage": {
        ".cs": "csharp"
      }
    },
    "rust-analyzer": {
      "command": "rust-analyzer",
      "args": [],
      "extensionToLanguage": {
        ".rs": "rust"
      }
    }
  },
  "mcpServers": {
    "hsp": {
      "command": "hsp",
      "args": ["mcp"],
      "env": {
        "HSP_ROUTER": "1"
      }
    }
  },
  "hooks": "./hooks/claude.json"
}
